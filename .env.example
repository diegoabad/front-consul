# API URL (Vite → nombre exacto VITE_API_URL).
#
# Producción (Netlify → API en Render): solo el origen del backend, sin barra final y sin /api:
#   VITE_API_URL=https://tu-servicio.onrender.com
# El código arma baseURL …/api; axios usa rutas /auth/login → …/api/auth/login en el servidor.
# (Si ponés …/api al final también funciona.)
#
# Mismo sitio Netlify con proxy /api → Render: podés dejar vacío o usar https://tu-app.netlify.app/api
#
# Local: API en el mismo puerto que escucha Express (suele 5000)
VITE_API_URL=http://localhost:5000

# Polling de la vista Turnos/Agenda cuando la pestaña está visible (ms). Mínimo 1000. Default 5000.
# Ver docs/agenda-actualizacion-tiempo-real.md
VITE_AGENDA_REFETCH_MS=5000
