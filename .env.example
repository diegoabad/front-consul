# API URL. Este proyecto usa Vite → la variable DEBE llamarse VITE_API_URL
# (no REACT_APP_API_URL). En Netlify: Environment variables → VITE_API_URL
# = valor de tu API en producción. Luego: Clear cache and deploy site.
VITE_API_URL=http://localhost:5000/api

# Polling de la vista Turnos/Agenda cuando la pestaña está visible (ms). Mínimo 1000. Default 5000.
# Ver docs/agenda-actualizacion-tiempo-real.md
VITE_AGENDA_REFETCH_MS=5000
